# Production env for tg-app-meet on the VPS.
# Copy to /opt/tg-app-meet/.env and fill the blanks.

# ---------- Domain ----------
# The Mini App is served at https://${DOMAIN}, API at https://${DOMAIN}/api
DOMAIN=meetappbot.online

# ---------- Postgres (internal only) ----------
POSTGRES_USER=tgmeet
POSTGRES_PASSWORD=CHANGE_ME_long_random_password
POSTGRES_DB=tgmeet

# ---------- API ----------
# Generate: `openssl rand -base64 48`
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random
# Generate: `openssl rand -hex 32`
ADMIN_TOKEN=CHANGE_ME_64hex_chars

# ---------- Telegram bot ----------
# From @BotFather
BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use /admin in the bot.
# Find yours by sending /start to @userinfobot.
ADMIN_TELEGRAM_IDS=
