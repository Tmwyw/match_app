# ---------- Database ----------
POSTGRES_USER=tgmeet
POSTGRES_PASSWORD=tgmeet
POSTGRES_DB=tgmeet
# Using 5544 to avoid clash with a locally-installed Postgres on 5432
POSTGRES_PORT=5544

# Prisma / NestJS
DATABASE_URL=postgresql://tgmeet:tgmeet@localhost:5544/tgmeet?schema=public

# ---------- API ----------
API_PORT=3001
JWT_SECRET=change-me-in-prod-please-32chars-min
# Long random hex (`openssl rand -hex 32`). Auths the /admin/* endpoints
# and the /admin?token=... web screen. Never commit a real value.
ADMIN_TOKEN=change-me-too-32hex-chars-minimum-or-longer
# CORS origin for the Mini App during dev
WEB_ORIGIN=http://localhost:5173

# ---------- Telegram bot ----------
# Token from @BotFather
BOT_TOKEN=
# Public URL of the Mini App (set after you expose it via cloudflared / ngrok)
WEB_APP_URL=https://example.com

# ---------- Web (Vite, must be prefixed with VITE_) ----------
VITE_API_URL=http://localhost:3001
