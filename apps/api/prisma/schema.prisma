generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  OWNER
}

model AnonCounter {
  role Role @id
  next Int  @default(1)
}

enum SwipeAction {
  LIKE
  SKIP
}

model User {
  id         String   @id @default(cuid())
  telegramId BigInt   @unique
  username   String?
  // role + anonId are assigned during onboarding (Phase 2), not at first auth
  role       Role?
  anonId     String?  @unique
  // Optional user-chosen nickname shown in cards, chat headers and messages
  // when set; falls back to anonId. Anti-deanon scrub runs on save (no @,
  // no t.me, no urls/phones/emails). Cleared on role-reset.
  displayName String?
  createdAt  DateTime @default(now())
  // Soft-delete: account never physically removed (would orphan reveals/chats
  // for the partner). Auth rejects re-login of a deleted telegramId.
  deletedAt  DateTime?
  // Set by admin via /admin/reports/:id/resolve { resolution: "banned" }.
  // JwtAuthGuard + WS middleware return 403 BANNED while bannedAt != null.
  bannedAt   DateTime?
  banReason  String?
  // Updated by ChatGateway on every connect/disconnect. Used to render
  // "был N мин назад" in chat headers when the partner is offline.
  lastSeenAt DateTime?
  // Set on FIRST auth from a `?start=ref_<id>` deep-link. Never updated
  // afterwards — back-dating attribution would let users farm referrals.
  referredById String?
  referredBy   User?   @relation("referrer", fields: [referredById], references: [id])
  // Bot stores `p_<userId>` deep-link payload here so Mini App opens the
  // intended user's card on next launch. Cleared once the frontend reads it.
  pendingViewProfile String?
  // Profile moderation. NULL = pending review (a profile row exists but
  // admin hasn't approved yet). Non-null = approved at this timestamp.
  // Discover excludes pending users in BOTH directions: pending users
  // can't browse others, and they don't appear in others' decks. Existing
  // users at migration time are backfilled with `createdAt` so they aren't
  // suddenly locked out.
  profileApprovedAt  DateTime?

  buyerProfile   BuyerProfile?
  ownerProfile   OwnerProfile?
  sentSwipes     Swipe[]         @relation("from")
  receivedSwipes Swipe[]         @relation("to")
  matchesA       Match[]         @relation("a")
  matchesB       Match[]         @relation("b")
  messages       Message[]
  reveals        ContactReveal[]
  reportsMade    Report[]        @relation("reporter")
  reportsAgainst Report[]        @relation("target")
  blocksMade     Block[]         @relation("blocker")
  blocksAgainst  Block[]         @relation("blocked")
  referred       User[]          @relation("referrer")
  notifPrefs     NotificationPrefs?
}

model BuyerProfile {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "Интересующая вакансия" — short label they're applying for
  // (CEO / Buyer / Контенщик …). May be empty for legacy rows.
  desiredPosition String   @default("")
  // "Источник трафика" — what traffic channels they want to work with.
  // Renamed from `verticals` to keep field names symmetric with OwnerProfile.
  trafficSources  String[]
  // "Вертикаль" — industry niche (Gambling, Crypto, …). Multi.
  verticals       String[]
  geos            String[]
  // "Желаемая зарплата" — salary range (was buyer's media-buying budget).
  // Field names stay budgetMin/Max for now to avoid an unnecessary migration.
  budgetMin       Int
  budgetMax       Int
  experience      Int
  // "Дополнительно" — anything not covered. Was `bio` ("О себе") — renamed
  // because the redesign drops the bio block from the buyer form entirely.
  notes           String?
  isActive        Boolean  @default(true)
}

model OwnerProfile {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "Кто нужен в команду?" — short label for the role/person they want.
  offerName      String
  // "Источник трафика" — multi-select with custom tags allowed
  // (FB, GOOGLE, TIKTOK, SEO, OTHER, …).
  trafficSources String[]
  // "Вертикаль" — industry niche (Gambling, Crypto, Dating, …). Multi.
  verticals      String[]
  geos           String[]
  // "Оплата" — salary/payment range, $ per agreed period. Both required.
  payoutMin      Int
  payoutMax      Int
  // "Дополнительно" — anything that didn't fit elsewhere.
  requirements   String?
  // Short team description (≤100 chars in UI).
  bio            String?
  isActive       Boolean  @default(true)
}

model Swipe {
  id        String      @id @default(cuid())
  fromId    String
  toId      String
  from      User        @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to        User        @relation("to", fields: [toId], references: [id], onDelete: Cascade)
  action    SwipeAction
  createdAt DateTime    @default(now())

  @@unique([fromId, toId])
  @@index([toId, action])
}

model Match {
  id           String   @id @default(cuid())
  userAId      String
  userBId      String
  userA        User     @relation("a", fields: [userAId], references: [id], onDelete: Cascade)
  userB        User     @relation("b", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  // Each side hides the match independently — archive is per-user, not
  // shared. Setting either flag does NOT mute the chat or kill realtime.
  archivedByA  Boolean  @default(false)
  archivedByB  Boolean  @default(false)
  chat         Chat?

  @@unique([userAId, userBId])
}

model Chat {
  id        String          @id @default(cuid())
  matchId   String          @unique
  match     Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  messages  Message[]
  reveals   ContactReveal[]
}

model Message {
  id        String    @id @default(cuid())
  chatId    String
  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  // Set when the recipient acks via WS message:read. NULL until then.
  readAt    DateTime?

  @@index([chatId, createdAt])
}

model ContactReveal {
  id         String   @id @default(cuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  acceptedAt DateTime @default(now())

  @@unique([chatId, userId])
}

model Report {
  id           String    @id @default(cuid())
  reporterId   String
  reporter     User      @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUserId String
  target       User      @relation("target", fields: [targetUserId], references: [id], onDelete: Cascade)
  chatId       String?
  reason       String // "spam" | "scam" | "deanon" | "abuse" | "other"
  details      String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolution   String? // "no_action" | "warned" | "banned"

  @@index([targetUserId, createdAt])
  @@index([resolvedAt])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model NotificationPrefs {
  userId     String    @id
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches    Boolean   @default(true)
  messages   Boolean   @default(true)
  // When true, message DMs are batched into a periodic digest instead of
  // firing one DM per chat. Match DMs always fire immediately.
  digestMode Boolean   @default(false)
  // Snooze: server skips non-match DMs while now < mutedUntil.
  mutedUntil DateTime?
  updatedAt  DateTime  @updatedAt
}
